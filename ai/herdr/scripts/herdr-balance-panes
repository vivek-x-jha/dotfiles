#!/usr/bin/env python3
"""Balance the current Herdr tab's pane layout."""

import json
import os
import socket
import subprocess
import sys
import time

herdr_bin = os.environ.get("HERDR_BIN", "herdr")
socket_path = os.environ.get("HERDR_SOCKET_PATH")
pane_id = os.environ.get("HERDR_PANE_ID")
if not socket_path or not pane_id:
    # Custom key commands are detached shell processes, so Herdr does not pass
    # pane variables. Its CLI retains the command's session context instead.
    try:
        status = json.loads(
            subprocess.check_output([herdr_bin, "status", "server", "--json"], text=True)
        )
        current = json.loads(
            subprocess.check_output([herdr_bin, "pane", "current"], text=True)
        )
        socket_path = status["socket"]
        pane_id = current["result"]["pane"]["pane_id"]
    except (KeyError, OSError, subprocess.CalledProcessError, json.JSONDecodeError) as error:
        sys.exit(f"herdr-balance-panes: cannot determine the current Herdr pane: {error}")


def request(method, params):
    request_id = f"herdr:balance:{time.time_ns()}"
    payload = {"id": request_id, "method": method, "params": params}
    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client:
        client.settimeout(1)
        client.connect(socket_path)
        client.sendall((json.dumps(payload) + "\n").encode())
        response = json.loads(client.recv(65536))
    if "error" in response:
        raise RuntimeError(response["error"].get("message", "unknown Herdr API error"))
    return response["result"]


layout = request("layout.export", {"pane_id": pane_id})["layout"]
splits = []
directions = set()


def leaf_count(node):
    if node["type"] == "pane":
        return 1
    return leaf_count(node["first"]) + leaf_count(node["second"])


def collect_splits(node, path=()):
    if node["type"] != "split":
        return
    first_leaves = leaf_count(node["first"])
    total_leaves = first_leaves + leaf_count(node["second"])
    splits.append((path, first_leaves / total_leaves))
    directions.add(node["direction"])
    # Herdr paths use false for the first child and true for the second.
    collect_splits(node["first"], path + (False,))
    collect_splits(node["second"], path + (True,))


collect_splits(layout["root"])
for path, equal_leaf_ratio in splits:
    # A single-axis tree is divided into equally sized panes. Mixed trees keep
    # every branch at 50:50, producing equal quarters for the usual 2×2 grid.
    ratio = equal_leaf_ratio if len(directions) == 1 else 0.5
    request(
        "layout.set_split_ratio",
        {"tab_id": layout["tab_id"], "path": list(path), "ratio": ratio},
    )

print(f"balanced {len(splits)} split(s)")
