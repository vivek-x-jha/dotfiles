// Secondary editor configuration. SourDiesel colors mirror WezTerm and Neovim.
{
    "workbench.colorTheme": "Dark Modern",
    "workbench.iconTheme": "vs-seti",
    "workbench.editor.showTabs": "none",
    "workbench.panel.defaultLocation": "right",
    "workbench.startupEditor": "none",
    "workbench.tree.enableStickyScroll": false,

    "editor.accessibilitySupport": "off",
    "editor.bracketPairColorization.enabled": true,
    "editor.cursorBlinking": "phase",
    "editor.cursorStyle": "block",
    "editor.fontFamily": "'JetBrainsMono Nerd Font', Menlo, 'DejaVu Sans Mono', Consolas, monospace",
    "editor.fontLigatures": true,
    "editor.fontSize": 15,
    "editor.fontWeight": "200",
    "editor.guides.bracketPairs": true,
    "editor.inlayHints.fontFamily": "'JetBrainsMono Nerd Font'",
    "editor.minimap.enabled": false,
    "editor.stickyScroll.enabled": false,
    "debug.console.fontFamily": "'JetBrainsMono Nerd Font'",

    "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
            "variable": "#cccccc",
            "variable.readonly": "#f4f3f2",
            "parameter": "#f4f3f2",
            "property": "#f4f3f2",
            "namespace": "#f4f3f2",
            "function": "#c4effa",
            "method": "#c4effa",
            "class": "#c4effa",
            "interface": "#c4effa",
            "type": "#fdf7cd",
            "typeParameter": "#fdf7cd",
            "enum": "#ffc7c7",
            "enumMember": "#f4f3f2",
            "keyword": "#eccef0",
            "modifier": "#eccef0",
            "number": "#ffc7c7",
            "string": "#ceffc9",
            "regexp": "#8ae7c5",
            "operator": "#cccccc",
            "decorator": "#cccccc",
            "macro": "#f4f3f2",
            "comment": {
                "foreground": "#5c617d",
                "italic": true
            }
        }
    },
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": ["comment", "punctuation.definition.comment"],
                "settings": { "foreground": "#5c617d", "fontStyle": "italic" }
            },
            {
                "scope": ["string", "string.quoted", "string.template"],
                "settings": { "foreground": "#ceffc9" }
            },
            {
                "scope": ["string.regexp", "constant.character.escape", "constant.character"],
                "settings": { "foreground": "#8ae7c5" }
            },
            {
                "scope": ["constant.numeric", "constant.language.boolean"],
                "settings": { "foreground": "#ffc7c7" }
            },
            {
                "scope": ["constant", "variable.other.constant"],
                "settings": { "foreground": "#f4f3f2" }
            },
            {
                "scope": ["keyword", "keyword.control", "storage.modifier"],
                "settings": { "foreground": "#eccef0" }
            },
            {
                "scope": ["entity.name.function", "support.function", "meta.function-call"],
                "settings": { "foreground": "#c4effa" }
            },
            {
                "scope": ["entity.name.class", "entity.name.interface"],
                "settings": { "foreground": "#c4effa" }
            },
            {
                "scope": ["storage.type", "entity.name.type", "support.type"],
                "settings": { "foreground": "#fdf7cd" }
            },
            {
                "scope": ["variable.parameter", "variable.other.property", "meta.object-literal.key"],
                "settings": { "foreground": "#f4f3f2" }
            },
            {
                "scope": ["variable", "identifier", "keyword.operator", "punctuation"],
                "settings": { "foreground": "#cccccc" }
            },
            {
                "scope": ["entity.name.tag"],
                "settings": { "foreground": "#f3b175" }
            },
            {
                "scope": ["entity.other.attribute-name"],
                "settings": { "foreground": "#f4f3f2" }
            },
            {
                "scope": ["markup.heading.1.markdown"],
                "settings": { "foreground": "#8ae7c5", "fontStyle": "bold" }
            },
            {
                "scope": ["markup.heading.2.markdown"],
                "settings": { "foreground": "#eccef0", "fontStyle": "bold" }
            },
            {
                "scope": ["markup.heading.3.markdown", "markup.heading.markdown"],
                "settings": { "foreground": "#c4effa", "fontStyle": "bold" }
            },
            {
                "scope": ["markup.raw", "markup.underline.link"],
                "settings": { "foreground": "#fdf7cd" }
            },
            {
                "scope": ["markup.inserted", "meta.diff.header.to-file"],
                "settings": { "foreground": "#ceffc9" }
            },
            {
                "scope": ["markup.deleted", "meta.diff.header.from-file", "invalid"],
                "settings": { "foreground": "#ffc7c7" }
            }
        ]
    },

    "workbench.colorCustomizations": {
        "focusBorder": "#c9ccfb",
        "foreground": "#f4f3f2",
        "descriptionForeground": "#5c617d",
        "disabledForeground": "#5c617d",
        "errorForeground": "#ffc7c7",
        "icon.foreground": "#cccccc",

        "activityBar.background": "#212030",
        "activityBar.foreground": "#f4f3f2",
        "activityBar.inactiveForeground": "#5c617d",
        "activityBar.activeBorder": "#8ae7c5",
        "activityBarBadge.background": "#eccef0",
        "activityBarBadge.foreground": "#1b1c28",
        "badge.background": "#eccef0",
        "badge.foreground": "#1b1c28",

        "titleBar.activeBackground": "#212030",
        "titleBar.activeForeground": "#f4f3f2",
        "titleBar.inactiveBackground": "#212030",
        "titleBar.inactiveForeground": "#5c617d",
        "titleBar.border": "#313244",
        "statusBar.background": "#27283a",
        "statusBar.foreground": "#f4f3f2",
        "statusBar.border": "#313244",
        "statusBar.debuggingBackground": "#27283a",
        "statusBar.debuggingForeground": "#ffc7c7",
        "statusBarItem.hoverBackground": "#313244",
        "statusBarItem.remoteBackground": "#27283a",
        "statusBarItem.remoteForeground": "#c9ccfb",

        "sideBar.background": "#212030",
        "sideBar.foreground": "#f4f3f2",
        "sideBar.border": "#313244",
        "sideBarTitle.foreground": "#c4effa",
        "sideBarSectionHeader.background": "#212030",
        "sideBarSectionHeader.foreground": "#cccccc",
        "sideBarSectionHeader.border": "#313244",
        "list.activeSelectionBackground": "#313244",
        "list.activeSelectionForeground": "#ffffff",
        "list.inactiveSelectionBackground": "#313244",
        "list.inactiveSelectionForeground": "#f4f3f2",
        "list.hoverBackground": "#313244",
        "list.hoverForeground": "#ffffff",
        "list.errorForeground": "#f096b7",
        "list.warningForeground": "#f3b175",

        "editor.background": "#212030",
        "editor.foreground": "#f4f3f2",
        "editorCursor.foreground": "#c9ccfb",
        "editorCursor.background": "#313244",
        "editorLineNumber.foreground": "#5c617d",
        "editorLineNumber.activeForeground": "#c9ccfb",
        "editor.selectionBackground": "#313244",
        "editor.selectionForeground": "#ffffff",
        "editor.inactiveSelectionBackground": "#313244",
        "editor.selectionHighlightBackground": "#313244",
        "editor.wordHighlightBackground": "#313244",
        "editor.wordHighlightStrongBackground": "#313244",
        "editor.findMatchBackground": "#fdf7cd",
        "editor.findMatchForeground": "#1b1c28",
        "editor.findMatchHighlightBackground": "#313244",
        "editor.lineHighlightBackground": "#313244",
        "editorBracketHighlight.foreground1": "#8ae7c5",
        "editorBracketHighlight.foreground2": "#eccef0",
        "editorBracketHighlight.foreground3": "#c4effa",
        "editorBracketHighlight.foreground4": "#fdf7cd",
        "editorBracketHighlight.foreground5": "#ceffc9",
        "editorBracketHighlight.foreground6": "#ffc7c7",
        "editorError.foreground": "#f096b7",
        "editorWarning.foreground": "#f3b175",
        "editorInfo.foreground": "#80d7fe",
        "editorHint.foreground": "#c9ccfb",
        "editorGutter.addedBackground": "#ceffc9",
        "editorGutter.modifiedBackground": "#fdf7cd",
        "editorGutter.deletedBackground": "#ffc7c7",
        "editorWidget.background": "#1b1c28",
        "editorWidget.foreground": "#f4f3f2",
        "editorWidget.border": "#5c617d",
        "editorHoverWidget.background": "#1b1c28",
        "editorHoverWidget.border": "#5c617d",
        "editorSuggestWidget.background": "#1b1c28",
        "editorSuggestWidget.border": "#5c617d",
        "editorSuggestWidget.selectedBackground": "#313244",
        "peekView.border": "#c9ccfb",
        "peekViewEditor.background": "#212030",
        "peekViewResult.background": "#1b1c28",

        "editorGroup.border": "#313244",
        "editorGroupHeader.tabsBackground": "#212030",
        "tab.activeBackground": "#313244",
        "tab.activeForeground": "#ffffff",
        "tab.activeBorderTop": "#8ae7c5",
        "tab.inactiveBackground": "#212030",
        "tab.inactiveForeground": "#5c617d",
        "tab.border": "#313244",
        "tab.hoverBackground": "#313244",
        "tab.hoverForeground": "#ffffff",

        "panel.background": "#212030",
        "panel.border": "#313244",
        "panelTitle.activeBorder": "#8ae7c5",
        "panelTitle.activeForeground": "#f4f3f2",
        "panelTitle.inactiveForeground": "#5c617d",
        "terminal.background": "#212030",
        "terminal.foreground": "#f4f3f2",
        "terminal.selectionBackground": "#313244",
        "terminalCursor.background": "#c9ccfb",
        "terminalCursor.foreground": "#313244",
        "terminal.ansiBlack": "#cccccc",
        "terminal.ansiRed": "#ffc7c7",
        "terminal.ansiGreen": "#ceffc9",
        "terminal.ansiYellow": "#fdf7cd",
        "terminal.ansiBlue": "#c4effa",
        "terminal.ansiMagenta": "#eccef0",
        "terminal.ansiCyan": "#8ae7c5",
        "terminal.ansiWhite": "#f4f3f2",
        "terminal.ansiBrightBlack": "#5c617d",
        "terminal.ansiBrightRed": "#f096b7",
        "terminal.ansiBrightGreen": "#d2fd9d",
        "terminal.ansiBrightYellow": "#f3b175",
        "terminal.ansiBrightBlue": "#80d7fe",
        "terminal.ansiBrightMagenta": "#c9ccfb",
        "terminal.ansiBrightCyan": "#47e7b1",
        "terminal.ansiBrightWhite": "#ffffff",

        "input.background": "#1b1c28",
        "input.foreground": "#f4f3f2",
        "input.border": "#5c617d",
        "input.placeholderForeground": "#5c617d",
        "dropdown.background": "#1b1c28",
        "dropdown.foreground": "#f4f3f2",
        "dropdown.border": "#5c617d",
        "button.background": "#313244",
        "button.foreground": "#f4f3f2",
        "button.hoverBackground": "#5c617d",
        "checkbox.background": "#1b1c28",
        "checkbox.foreground": "#c9ccfb",
        "checkbox.border": "#5c617d",
        "quickInput.background": "#1b1c28",
        "quickInput.foreground": "#f4f3f2",
        "quickInputList.focusBackground": "#313244",
        "quickInputList.focusForeground": "#ffffff",
        "menu.background": "#1b1c28",
        "menu.foreground": "#f4f3f2",
        "menu.selectionBackground": "#313244",
        "menu.selectionForeground": "#ffffff",
        "notifications.background": "#1b1c28",
        "notifications.foreground": "#f4f3f2",
        "notifications.border": "#5c617d",
        "notificationLink.foreground": "#c4effa",
        "progressBar.background": "#8ae7c5",

        "textLink.foreground": "#c4effa",
        "textLink.activeForeground": "#80d7fe",
        "textPreformat.foreground": "#ceffc9",
        "textCodeBlock.background": "#313244",
        "textBlockQuote.background": "#1b1c28",
        "textBlockQuote.border": "#fdf7cd",

        "gitDecoration.addedResourceForeground": "#ceffc9",
        "gitDecoration.modifiedResourceForeground": "#fdf7cd",
        "gitDecoration.deletedResourceForeground": "#ffc7c7",
        "gitDecoration.renamedResourceForeground": "#c4effa",
        "gitDecoration.untrackedResourceForeground": "#d2fd9d",
        "gitDecoration.ignoredResourceForeground": "#5c617d",
        "gitDecoration.conflictingResourceForeground": "#f096b7"
    },

    "terminal.external.osxExec": "WezTerm.app",
    "terminal.external.linuxExec": "wezterm",
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.cursorStyle": "block",
    "terminal.integrated.defaultProfile.osx": "zsh",
    "terminal.integrated.drawBoldTextInBrightColors": false,
    "terminal.integrated.enablePersistentSessions": false,
    "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font', Menlo, 'DejaVu Sans Mono', Consolas, monospace",
    "terminal.integrated.fontSize": 15,
    "terminal.integrated.fontWeight": "200",
    "terminal.integrated.fontWeightBold": "500",
    "terminal.integrated.inheritEnv": true,
    "terminal.integrated.minimumContrastRatio": 1,
    "terminal.integrated.shellIntegration.enabled": true,

    "explorer.compactFolders": false,
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "git.confirmSync": false,
    "security.workspace.trust.untrustedFiles": "open",
    "window.confirmSaveUntitledWorkspace": false,
    "window.customTitleBarVisibility": "windowed",
    "window.newWindowDimensions": "fullscreen",
    "window.restoreFullscreen": true,
    "window.titleBarStyle": "custom"
}
