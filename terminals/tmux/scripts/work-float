#!/usr/bin/env bash
set -euo pipefail

state_home="${XDG_STATE_HOME:-$HOME/.local/state}"
data_home="${XDG_DATA_HOME:-$HOME/.local/share}"
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:$HOME/.local/bin:$data_home/cargo/bin:$PATH"
restore_lock="$state_home/tmux/work-restore.lock"
wait_timeout="${WORK_FLOAT_RESTORE_WAIT_TIMEOUT:-60}"
stale_after="${WORK_FLOAT_RESTORE_LOCK_STALE_AFTER:-300}"

wait_for_work_restore() {
  local start now lock_pid lock_started
  start="$(date +%s)"

  while [[ -e "$restore_lock" ]]; do
    now="$(date +%s)"
    lock_pid=''
    lock_started=''
    read -r lock_pid lock_started <"$restore_lock" 2>/dev/null || true

    if [[ $lock_started =~ ^[0-9]+$ ]] && ((now - lock_started > stale_after)); then
      rm -f "$restore_lock" 2>/dev/null || true
      break
    fi

    if ((now - start >= wait_timeout)); then
      printf 'work-float: timed out waiting for work -r restore lock: %s\n' "$restore_lock" >&2
      return 1
    fi

    sleep 0.2
  done
}

wait_for_work_restore
source "$HOME/.dotfiles/shells/bash/funcs/work"
work float
