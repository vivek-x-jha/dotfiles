# Shared aliases for bash and zsh

# -------------------------------- File Editing ---------------------------------------

# Open vim using viminfo state file
alias vi='vim -i "$XDG_STATE_HOME/vim/viminfo"'

# Recover Neovim ShaDa state when temp file write slots are stuck
command -v nvim &>/dev/null && alias reload-shada='mv -f "$XDG_STATE_HOME/nvim/shada/main.shada.tmp.x" "$XDG_STATE_HOME/nvim/shada/main.shada"'

# -------------------------------- File Management & Previewing ---------------------------------------

# Move up 2 directories
alias ...="cd ../.."

# uses value of $GREP_COLOR
alias grep='grep --color=auto'

# Fuzzy search man pages
command -v fzf &>/dev/null && alias docs='compgen -c | fzf | xargs man'

# -------------------------------- List Long Functions ---------------------------------------

# Outputs System info
alias list-path='tr ":" "\n" <<< "$PATH"'
alias list-fpath='tr ":" "\n" <<< "$FPATH"'
alias list-shells='tail -n +5 /etc/shells'
alias list-sysinfo='system_profiler SPSoftwareDataType SPHardwareDataType'
alias list-users='dscl . list /Users | grep -v "^_"'

# Outputs Cargo package names
command -v cargo &>/dev/null && alias list-cargo='cargo install --list | awk '\''/^[^[:space:]].*:$/ { sub(/ .*/, ""); sub(/:$/, ""); print }'\'''

# Outputs shell syntax highlighting
alias list-highlighter='print -raC2 - "${(@kvq+)ZSH_HIGHLIGHT_STYLES}" | sort'

# Outputs Homebrew package info
command -v brew &>/dev/null && {
  alias list-apps='brew list --cask | xargs -n1'
  alias list-cmds='brew list --formula | xargs -n1'
  alias list-deps='brew deps --tree --installed'
}

# -------------------------------- Version Control ---------------------------------------

# Git
command -v git &>/dev/null && {
  alias gaa='git add --all'
  alias gd='git diff'
  alias gds='git diff --staged'
  alias gp='git push'
  alias grs='git restore'
  alias grst='git restore --staged'
  alias grv='git remote --verbose'
  alias gst='git status -s'

  command -v fzf &>/dev/null && {
    alias gsw='git branch --format="%(refname:short)" \
      | fzf \
        --header "git switch" \
        --border-label "  branches " \
        --preview "git show --color=always {1}" \
      | xargs -r git switch'
  }
}

# -------------------------------- CLI tools ---------------------------------------

# Pi quick entrypoints by cost/quality tier.
command -v pi &>/dev/null && {
  # Cheap cloud one-shot using the Codex mini model with low thinking.
  alias ask='pi -p --provider openai-codex --model gpt-5.4-mini --thinking low --no-session'

  # Free local one-shot for simple chat-style questions via Ollama.
  alias askq='pi -p --model ollama/qwen2.5-coder:7b --no-session --no-tools --no-context-files --no-skills --no-prompt-templates'

  # Free local coding chats via Ollama, from lightest to strongest.
  alias piq='pi --model ollama/qwen2.5-coder:7b'
  alias piq14='pi --model ollama/qwen2.5-coder:14b'
  alias piq32='pi --model ollama/qwen2.5-coder:32b'

  # Cloud coding/reasoning tiers supported by ChatGPT-account authentication.
  alias pilight='pi --provider openai-codex --model gpt-5.4-mini --thinking low'
  alias pistrong='pi --provider openai-codex --model gpt-5.5 --thinking high'
  alias pimax='pi --provider openai-codex --model gpt-5.5 --thinking xhigh'
}

# CLIProxyAPI creates OAuth files using the caller's umask; keep credentials private.
command -v cliproxyapi &>/dev/null && cliproxyapi() (
  umask 077
  command cliproxyapi "$@"
)

# Run Claude Code against GPT-5.6-Sol through the loopback-only CLIProxyAPI service.
command -v claude &>/dev/null && command -v cliproxyapi &>/dev/null && {
  alias claudex='ANTHROPIC_BASE_URL=http://127.0.0.1:8317 \
    ANTHROPIC_AUTH_TOKEN=sk-dummy \
    CLAUDE_CODE_SUBAGENT_MODEL=gpt-5.6-sol \
    CLAUDE_CODE_ALWAYS_ENABLE_EFFORT=1 \
    CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY=3 \
    ENABLE_TOOL_SEARCH=false \
    claude --model gpt-5.6-sol'
}

# https://developer.1password.com/docs/cli/shell-plugins
command -v op &>/dev/null && {
  command -v gh &>/dev/null && alias gh="op plugin run -- gh"

  _op_mysql_connect() {
    local client="$1"
    local user="$2"
    local password
    local secret_file
    local exit_code
    shift 2

    password="$(op item get "MySQL User: $user" --vault Private --field 'password' --reveal)" || return
    secret_file="$(mktemp "${TMPDIR:-/tmp}/${client}-op.XXXXXX")" || return
    chmod 600 "$secret_file"
    trap 'rm -f "$secret_file"' EXIT INT TERM

    case "$client" in
    mysql)
      {
        printf '[client]\n'
        printf 'user=%s\n' "$user"
        printf 'password=%s\n' "$password"
      } >"$secret_file"
      command mysql --defaults-file="$secret_file" "$@"
      ;;
    mycli)
      printf '%s\n' "$password" >"$secret_file"
      command mycli --myclirc "$XDG_CONFIG_HOME/mycli/config" -u "$user" --password-file "$secret_file" "$@"
      ;;
    esac

    exit_code=$?
    rm -f "$secret_file"
    trap - EXIT INT TERM
    return "$exit_code"
  }

  command -v mysql &>/dev/null && {
    alias mysql='_op_mysql_connect mysql "$USER"'
    alias mysql-root='_op_mysql_connect mysql root'
  }

  command -v mycli &>/dev/null && {
    alias mycli='_op_mysql_connect mycli "$USER"'
    alias mycli-root='_op_mysql_connect mycli root'
  }
}

