#!/usr/bin/env bash

work() {
  command -v tmux >/dev/null 2>&1 || {
    printf 'tmux not available\n' >&2
    return 1
  }

  local window_label='main'
  local left_label='edit'
  local top_right_label=''
  local bottom_right_label='test'
  local left_cmd='nvim'
  local top_right_cmd='codex resume --last'
  local bottom_right_cmd='clear;'
  local root=''
  local python_init=0

  usage() {
    cat <<'EOF'
Usage: work <options> <session>

Options:
  -h, --help                     Show this help message and exit
  -r, --reload                   Kill current tmux server and start a fresh session
  -p, --python                   Initialize Python project (runs 'uvi' if no pyproject.toml)

Layout customization:
  --window-label NAME            Set the tmux window name (default: main)
  --left-label NAME              Pane 1 (left) label (default: edit)
  --top-right-label NAME         Pane 2 (top-right) label (default: project root)
  --bottom-right-label NAME      Pane 3 (bottom-right) label (default: test)

Command customization:
  --left-cmd CMD                 Command for left pane (default: nvim)
  --top-right-cmd CMD            Command for top-right pane (default: 'codex resume --last')
  --bottom-right-cmd CMD         Command for bottom-right pane (default: 'clear;')

Examples:
  work                           Attach or create default session
  work myapp                     Open session in ~/developer/myapp
  work --window-label dev myapp  Custom window name
  work -r                        Reset tmux server (tmux kill-server && tmux new-session)
EOF
  }

  while [[ $# -gt 0 ]]; do
    case "$1" in
    -h | --help)
      usage
      return 0
      ;;
    -r | --reload)
      if [[ -n $TMUX ]]; then
        printf "Stopping tmux server... rerun \`work -r\` once tmux exits to start fresh.\n"
        tmux kill-server >/dev/null 2>&1
        return 0
      fi

      tmux list-sessions >/dev/null 2>&1 && tmux kill-server >/dev/null 2>&1

      local reload_session='__work_reload__'
      local restore_script="${TMUX_PLUGIN_MANAGER_PATH:-$HOME/.tmux/plugins}/tmux-resurrect/scripts/restore.sh"
      local preferred_session=''
      local attempt=0

      while ((attempt < 3)); do
        preferred_session=''
        if TMUX='' tmux new-session -ds "$reload_session" -c "$HOME"; then
          if [[ -x $restore_script ]]; then
            tmux run-shell "$restore_script"

            local test_pane
            while IFS= read -r test_pane; do
              [[ -n $test_pane ]] || continue
              tmux send-keys -t "$test_pane" -l -- 'clear'
              tmux send-keys -t "$test_pane" C-m
            done < <(tmux list-panes -a -F '#{pane_id} #{pane_title}' | awk '$2=="test"{print $1}')

            local resurrect_dir
            resurrect_dir="$(tmux show-option -gqv '@resurrect-dir')"
            if [[ -z $resurrect_dir ]]; then
              if [[ -d $HOME/.tmux/resurrect ]]; then
                resurrect_dir="$HOME/.tmux/resurrect"
              else
                resurrect_dir="${XDG_DATA_HOME:-$HOME/.local/share}/tmux/resurrect"
              fi
            fi

            local last_file="$resurrect_dir/last"
            if [[ -f $last_file ]]; then
              preferred_session="$(awk -F'\t' '$1=="state"{current=$2} END{print current}' "$last_file")"
              [[ -z $preferred_session ]] &&
                preferred_session="$(awk -F'\t' '$1=="state"{previous=$3} END{print previous}' "$last_file")"
            fi

            [[ -n $preferred_session && $preferred_session != "$reload_session" ]] || preferred_session=''

            tmux list-sessions -F '#S' | grep -qv "^${reload_session}$" &&
              tmux kill-session -t "$reload_session" >/dev/null 2>&1
          fi

          if [[ -n $preferred_session ]]; then
            tmux attach-session -t "$preferred_session"
            return $?
          fi

          tmux attach-session || tmux new-session
          return $?
        fi
        sleep 0.5
        attempt=$((attempt + 1))
      done

      printf 'work: failed to start new tmux session after reload.\n' >&2
      return 1
      ;;
    -p | --python)
      python_init=1
      shift
      ;;
    --window-label)
      window_label="$2"
      shift 2
      ;;
    --left-label)
      left_label="$2"
      shift 2
      ;;
    --top-right-label)
      top_right_label="$2"
      shift 2
      ;;
    --bottom-right-label)
      bottom_right_label="$2"
      shift 2
      ;;
    --left-cmd)
      left_cmd="$2"
      shift 2
      ;;
    --top-right-cmd)
      top_right_cmd="$2"
      shift 2
      ;;
    --bottom-right-cmd)
      bottom_right_cmd="$2"
      shift 2
      ;;
    --)
      shift
      break
      ;;
    *) break ;;
    esac
  done

  local session="$1"
  local should_prompt_description=0

  case "$session" in
  '')
    if [[ -n $TMUX ]]; then
      [[ -t 0 ]] || return 0
      tmux list-sessions
      return $?
    fi

    [[ -t 0 ]] || return 0
    tmux attach-session || tmux new-session
    return $?
    ;;
  nvim | wezterm) root="$HOME/.dotfiles" ;;
  *)
    root="$HOME/developer/$session"
    should_prompt_description=1
    ;;
  esac

  [[ -z $top_right_label ]] && top_right_label="$(basename "$root")"

  swatt() {
    local target="$1"
    if [[ -n $TMUX ]]; then
      tmux switch-client -t "$target" 2>/dev/null || tmux switch-client -l
    else
      tmux attach-session -t "$target" 2>/dev/null || tmux attach-session
    fi
  }

  tmux has-session -t "$session" >/dev/null 2>&1 && {
    swatt "$session"
    return $?
  }

  local description=''
  if ((should_prompt_description)); then
    local prompt
    printf -v prompt '%bEnter description? %b' "$BRIGHTYELLOW" "$RESET"
    if [[ -t 0 ]]; then
      read -r -p "$prompt" REPLY
    fi
    description="${REPLY:+: $REPLY}"
    top_right_cmd+=" '$session$description'"
  fi

  if ((python_init)); then
    local uvi_desc=''
    printf -v uvi_desc '%q' "$REPLY"
    bottom_right_cmd+=" if test ! -f pyproject.toml; then uvi -d $uvi_desc; fi"
  fi

  tmux_template() {
    local left_id="$session:$window_label.1"
    local top_right_id="$session:$window_label.2"
    local bottom_right_id="$session:$window_label.3"

    mkdir -p "$root/prompts"
    tmux new-session -d -s "$session" -c "$root" -n "$window_label"
    tmux split-window -h -t "$left_id" -c "$root"
    tmux split-window -v -t "$top_right_id" -c "$root"
    tmux select-pane -t "$left_id" -T "$left_label"
    tmux select-pane -t "$top_right_id" -T "$top_right_label"
    tmux select-pane -t "$bottom_right_id" -T "$bottom_right_label"
    tmux send-keys -t "$left_id" -l -- "$left_cmd"
    tmux send-keys -t "$left_id" C-m
    tmux send-keys -t "$top_right_id" -l -- "$top_right_cmd"
    tmux send-keys -t "$top_right_id" C-m
    tmux send-keys -t "$bottom_right_id" -l -- "$bottom_right_cmd"
    tmux send-keys -t "$bottom_right_id" C-m
    tmux select-pane -t "$bottom_right_id"
  }

  tmux_template || {
    printf 'work: failed to scaffold session %s\n' "$session" >&2
    usage
    return 1
  }

  swatt "$session"
}
