#!/usr/bin/env bash

update-branches() {
  local branches=("$@")

  command -v git >/dev/null 2>&1 || {
    printf "%b[ERROR] git not found on PATH%b\n" "$RED" "$RESET" >&2
    return 1
  }

  local default
  default=$(git config --get init.defaultBranch 2>/dev/null)
  default=${default:-main}

  local original_branch
  original_branch=$(git branch --show-current 2>/dev/null)

  if ((${#branches[@]} == 0)); then
    local candidate
    for candidate in dev develop; do
      git show-ref --verify --quiet "refs/heads/$candidate" && branches+=("$candidate")
    done
  fi

  local filtered=()
  local branch
  for branch in "${branches[@]}"; do
    [[ -z $branch || $branch == "$default" ]] && continue

    local seen=0
    local existing
    for existing in "${filtered[@]}"; do
      [[ $existing == "$branch" ]] && seen=1 && break
    done
    ((seen)) && continue

    filtered+=("$branch")
  done
  branches=("${filtered[@]}")

  ((${#branches[@]})) || {
    printf "%b[WARN] no branches updated%b\n" "$YELLOW" "$RESET"
    printf "%b[INFO] pass branch names, e.g. %b\`update-branches dev\`%b\n" "$BLACK" "$GREEN" "$BLACK"
    return 0
  }

  local rc=0
  for branch in "${branches[@]}"; do
    git show-ref --verify --quiet "refs/heads/$branch" || {
      printf "%b[ERROR] '%s' not found%b\n" "$RED" "$branch" "$RESET"
      rc=1
      continue
    }

    git switch "$branch" >/dev/null 2>&1 || {
      rc=1
      continue
    }

    git merge "$default" >/dev/null 2>&1 || {
      rc=1
      continue
    }

    printf "%b✔ %b%b%s%b <- %b%s%b\n" "$GREEN" "$RESET" "$CYAN" "$branch" "$RESET" "$MAGENTA" "$default" "$RESET"
  done

  if [[ -n $original_branch ]]; then
    git switch "$original_branch" >/dev/null 2>&1 || rc=1
  else
    git switch "$default" >/dev/null 2>&1 || rc=1
  fi

  return "$rc"
}
