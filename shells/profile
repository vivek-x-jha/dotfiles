# Shared login profile for bash and zsh

remove_path() {
  PATH=":$PATH:"
  PATH="${PATH//:$1:/:}"
  PATH="${PATH#:}"
  PATH="${PATH%:}"
}

prepend_path() { remove_path "$1" && PATH="$1${PATH:+:$PATH}"; }
append_path() { remove_path "$1" && PATH="${PATH:+$PATH:}$1"; }

# Add MacOS tools - Homebrew + iTerm2 utilities
[[ $(uname) == Darwin ]] && {
  prepend_path '/opt/homebrew/sbin'
  prepend_path '/opt/homebrew/bin'
  append_path '/Applications/iTerm.app/Contents/Resources/utilities'
}

# Give AI harnesses enough descriptors for MCP servers, skills, and subprocesses.
[[ $(ulimit -Sn) != unlimited && $(ulimit -Sn) -lt 10240 ]] && ulimit -Sn 10240

# Add user-managed tool directories
prepend_path "$HOME/.local/bin"
prepend_path "$XDG_DATA_HOME/fzf/bin"
prepend_path "$CARGO_HOME/bin"
prepend_path "$XDG_DATA_HOME/bob/nvim-bin"

export PATH

# Load secrets after PATH setup so private overrides see the final baseline environment
# Use a regular file only; special files such as FIFOs can block shell startup
# shellcheck disable=SC1091
[[ -f "$HOME/.dotfiles/.env" ]] && source "$HOME/.dotfiles/.env"

unset -f remove_path prepend_path append_path
