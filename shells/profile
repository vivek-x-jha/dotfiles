# Shared login/interactive profile for bash and zsh

# This file may be sourced by both login and interactive startup paths in the
# same shell process. Keep side effects idempotent.
[[ ${DOTFILES_PROFILE_LOADED:-0} == 1 ]] && return 0
DOTFILES_PROFILE_LOADED=1

# Essential environment and PATH setup lives in shells/env, reached by ~/.zshenv.
# Give AI harnesses enough descriptors for MCP servers, skills, and subprocesses.
[[ $(ulimit -Sn) != unlimited && $(ulimit -Sn) -lt 10240 ]] && ulimit -Sn 10240

# Load secrets after PATH setup so private overrides see the final baseline environment
# Use a regular file only; special files such as FIFOs can block shell startup
# shellcheck disable=SC1091
[[ -f "$HOME/.dotfiles/.env" ]] && source "$HOME/.dotfiles/.env"
