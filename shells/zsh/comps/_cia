#compdef cia

autoload -U is-at-least

_cia() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--project=[Preselect the project matching this working directory]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_cia_commands" \
"*::: :->cia" \
&& ret=0
    case $state in
    (cia)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:cia-command-$line[1]:"
        case $line[1] in
            (open)
_arguments "${_arguments_options[@]}" : \
'--harness=[Harness to search\: pi, claude, codex, cursor, opencode, or all]:HARNESS:_default' \
'--project=[Preselect the project matching this working directory]:PATH:_files' \
'--archived[Search archived threads instead of active threads]' \
'-h[Print help]' \
'--help[Print help]' \
':query -- Thread name, title, or preview text to search for:_default' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'--project=[Preselect the project matching this working directory]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(run-thread)
_arguments "${_arguments_options[@]}" : \
'--thread-id=[]:THREAD_ID:_default' \
'--cwd-hex=[]:CWD_HEX:_default' \
'--title-hex=[]:TITLE_HEX:_default' \
'--harness-id=[]:HARNESS_ID:_default' \
'--agent-command-hex=[]:AGENT_COMMAND_HEX:_default' \
'--codex-command-hex=[]:CODEX_COMMAND_HEX:_default' \
'--session-dir-hex=[]:SESSION_DIR_HEX:_default' \
'--project=[Preselect the project matching this working directory]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_cia__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:cia-help-command-$line[1]:"
        case $line[1] in
            (open)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(run-thread)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_cia_commands] )) ||
_cia_commands() {
    local commands; commands=(
'open:Open the most recent saved thread matching a name or title' \
'completions:Generate shell completions' \
'run-thread:Resume an agent thread while preserving tmux metadata' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'cia commands' commands "$@"
}
(( $+functions[_cia__subcmd__completions_commands] )) ||
_cia__subcmd__completions_commands() {
    local commands; commands=()
    _describe -t commands 'cia completions commands' commands "$@"
}
(( $+functions[_cia__subcmd__help_commands] )) ||
_cia__subcmd__help_commands() {
    local commands; commands=(
'open:Open the most recent saved thread matching a name or title' \
'completions:Generate shell completions' \
'run-thread:Resume an agent thread while preserving tmux metadata' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'cia help commands' commands "$@"
}
(( $+functions[_cia__subcmd__help__subcmd__completions_commands] )) ||
_cia__subcmd__help__subcmd__completions_commands() {
    local commands; commands=()
    _describe -t commands 'cia help completions commands' commands "$@"
}
(( $+functions[_cia__subcmd__help__subcmd__help_commands] )) ||
_cia__subcmd__help__subcmd__help_commands() {
    local commands; commands=()
    _describe -t commands 'cia help help commands' commands "$@"
}
(( $+functions[_cia__subcmd__help__subcmd__open_commands] )) ||
_cia__subcmd__help__subcmd__open_commands() {
    local commands; commands=()
    _describe -t commands 'cia help open commands' commands "$@"
}
(( $+functions[_cia__subcmd__help__subcmd__run-thread_commands] )) ||
_cia__subcmd__help__subcmd__run-thread_commands() {
    local commands; commands=()
    _describe -t commands 'cia help run-thread commands' commands "$@"
}
(( $+functions[_cia__subcmd__open_commands] )) ||
_cia__subcmd__open_commands() {
    local commands; commands=()
    _describe -t commands 'cia open commands' commands "$@"
}
(( $+functions[_cia__subcmd__run-thread_commands] )) ||
_cia__subcmd__run-thread_commands() {
    local commands; commands=()
    _describe -t commands 'cia run-thread commands' commands "$@"
}

if [ "$funcstack[1]" = "_cia" ]; then
    _cia "$@"
else
    compdef _cia cia
fi
