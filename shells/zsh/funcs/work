#!/usr/bin/env zsh

# Ensure tmux available
command -v tmux &>/dev/null || {
  printf 'tmux not available\n' >&2
  return 1
}

local window_label='main'
local left_label='edit'
local right_label='test'
local agents_label='agents'

local left_cmd='nvim'
local right_cmd='clear;'
local agents_cmd='codex resume'

local python_init=0

# Doc helper
usage() {
  cat <<'EOF'
Usage: work <options> <session>

Options:
  -h, --help                     Show this help message and exit
  -r, --reload                   Kill current tmux server and start a fresh session
  -p, --python                   Initialize Python project (runs 'uvi' if no pyproject.toml)

Layout customization:
  --window-label NAME            Set the tmux window name (default: main)
  --left-label NAME              Pane 1 (left) label (default: edit)
  --right-label NAME             Pane 2 (right) label (default: test)
  --agents-label NAME            Agent window name (default: agents)

Command customization:
  --left-cmd CMD                 Command for left pane (default: nvim)
  --right-cmd CMD                Command for right pane (default: 'clear;')
  --agents-cmd CMD               Command for agent window (default: 'codex resume')

Examples:
  work                           Attach or create default session
  work myapp                     Open session in ~/developer/myapp
  work --window-label dev myapp  Custom window name
  work -r                        Reset tmux server (tmux kill-server && tmux new-session)
EOF
}

# Handle <options> for different project setups
while [[ $# -gt 0 ]]; do
  case "$1" in
  -h | --help)
    usage
    return
    ;;

  -r | --reload)
    [[ -n $TMUX ]] && {
      printf 'Stopping tmux server... rerun `work -r` once tmux exits to start fresh.\n'
      tmux kill-server &>/dev/null
      return
    }

    tmux list-sessions &>/dev/null && tmux kill-server &>/dev/null

    local reload_session='__work_reload__'
    local restore_script="$TMUX_PLUGIN_MANAGER_PATH/tmux-resurrect/scripts/restore.sh"
    local preferred_session=''

    local attempt=0
    while ((attempt < 3)); do
      preferred_session=''
      TMUX='' tmux new-session -ds "$reload_session" -c "$HOME" && {
        [[ -x "$restore_script" ]] && {
          tmux run-shell "$restore_script"

          local test_pane
          while IFS= read -r test_pane; do
            [[ -n "$test_pane" ]] || continue
            tmux send-keys -t "$test_pane" -l -- 'clear'
            tmux send-keys -t "$test_pane" C-m
          done < <(tmux list-panes -a -F '#{pane_id} #{pane_title}' | awk '$2=="test"{print $1}')

          local resurrect_dir
          resurrect_dir="$(tmux show-option -gqv '@resurrect-dir')"
          if [[ -z "$resurrect_dir" ]]; then
            if [[ -d "$HOME/.tmux/resurrect" ]]; then
              resurrect_dir="$HOME/.tmux/resurrect"
            else
              resurrect_dir="${XDG_DATA_HOME:-$HOME/.local/share}/tmux/resurrect"
            fi
          fi

          local last_file="$resurrect_dir/last"
          [[ -f "$last_file" ]] && {
            preferred_session="$(awk -F'\t' '$1=="state"{current=$2} END{print current}' "$last_file")"
            [[ -z "$preferred_session" ]] &&
              preferred_session="$(awk -F'\t' '$1=="state"{previous=$3} END{print previous}' "$last_file")"
          }

          [[ -n "$preferred_session" && "$preferred_session" != "$reload_session" ]] || preferred_session=''

          tmux list-sessions -F '#S' | grep -qv "^${reload_session}$" && tmux kill-session -t "$reload_session" &>/dev/null
        }

        [[ -n "$preferred_session" ]] && tmux attach-session -t "$preferred_session" && return $?
        tmux attach-session || tmux new-session
        return $?
      }

      sleep 0.5
      attempt=$((attempt + 1))
    done

    printf 'work: failed to start new tmux session after reload.\n' >&2
    return 1
    ;;

  -p | --python)
    python_init=1
    shift
    ;;

  --window-label)
    window_label="$2"
    shift 2
    ;;

  --left-label)
    left_label="$2"
    shift 2
    ;;

  --right-label | --bottom-right-label)
    right_label="$2"
    shift 2
    ;;

  --agents-label | --top-right-label)
    agents_label="$2"
    shift 2
    ;;

  --left-cmd)
    left_cmd="$2"
    shift 2
    ;;

  --right-cmd | --bottom-right-cmd)
    right_cmd="$2"
    shift 2
    ;;

  --agents-cmd | --top-right-cmd)
    agents_cmd="$2"
    shift 2
    ;;

  --) shift && break ;;
  *) break ;;
  esac
done

# Handle <sessions> for different project setups
local session="$1"
local root="$HOME/developer/$session"

[[ -z $session ]] && {
  # If run without args inside TMUX session -> mutate to `tmux list-sessions`
  [[ -n $TMUX ]] && {
    [[ -t 0 ]] || return 0
    tmux list-sessions
    return $?
  }

  # If run without args outside TMUX session -> mutate to `tmux attach-session or new-session`
  [[ -t 0 ]] || return 0
  tmux attach-session || tmux new-session
  return $?
}

configure_float_session() {
  local target="$1"
  [[ "$target" == float ]] || return 0

  tmux set-option -t "$target" status off || return 1

  local window_id
  while IFS= read -r window_id; do
    [[ -n "$window_id" ]] || continue
    tmux set-window-option -t "$window_id" pane-border-status off || return 1
  done < <(tmux list-windows -t "$target" -F '#{window_id}')
}

# Helper func: respects whether current shell is already inside tmux
swatt() {
  local target="$1"
  configure_float_session "$target" || return 1

  if [[ -n $TMUX ]]; then
    tmux switch-client -t "$target" 2>/dev/null || tmux switch-client -l
  else
    tmux attach-session -t "$target" 2>/dev/null || tmux attach-session
  fi
}

# Short circuit if session already exists
tmux has-session -t "$session" &>/dev/null && {
  swatt "$session"
  return $?
}

((python_init)) && {
  local uvi_desc=''
  printf -v uvi_desc '%q' "$session"
  right_cmd+=" if test ! -f pyproject.toml; then uvi -d $uvi_desc; fi"
}

# General template creator
# TODO expand for different templates
tmux_template() {
  local left_id="$session:$window_label.1"
  local right_id="$session:$window_label.2"
  local agents_id="$session:$agents_label.1"

  # Setup project structure
  mkdir -p "$root/prompts"

  # Initialize session with given configuration
  tmux new-session -d -s "$session" -c "$root" -n "$window_label"

  # Configure window layout
  tmux split-window -h -t "$left_id" -c "$root"

  # Label panes
  tmux select-pane -t "$left_id" -T "$left_label"
  tmux select-pane -t "$right_id" -T "$right_label"

  # Execute startup commands
  [[ -n $left_cmd ]] && {
    tmux send-keys -t "$left_id" -l -- "$left_cmd"
    tmux send-keys -t "$left_id" C-m
  }

  tmux send-keys -t "$right_id" -l -- "$right_cmd"
  tmux send-keys -t "$right_id" C-m

  # Create the agent window after the main project panes.
  tmux new-window -t "$session" -c "$root" -n "$agents_label"
  tmux select-pane -t "$agents_id" -T "$agents_label"
  tmux send-keys -t "$agents_id" -l -- "$agents_cmd"
  tmux send-keys -t "$agents_id" C-m
}

tmux_template || {
  printf 'work: failed to scaffold session %s\n' "$session" >&2
  usage
  return 1
}

swatt "$session"
return $?
