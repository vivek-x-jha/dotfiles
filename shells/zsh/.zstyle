#!/usr/bin/env zsh

zstyle ':completion:*:unambiguous' format \
  $'%{\e[0;2m%}%Bcommon substring:%b %{\e[0m%}%{\e[38;5;1m%}%d%{\e[0m%}'

zstyle ':completion:*:-command-:*' format \
  $'%{\e[0;1;2m%}< %{\e[0m%}%{\e[38;5;5m%}%d%{\e[0m%}%{\e[0;1;2m%} >%{\e[0m%}'
zstyle ':completion:*:descriptions' format \
  $'%{\e[0;1;2m%}< %{\e[0m%}%{\e[38;5;5m%}%d%{\e[0m%}%{\e[0;1;2m%} >%{\e[0m%}'

# Keep completion menus structural; detailed filename patterns belong to eza.
zsh_completion_colors=(
  'no=00;38;5;0'
  'fi=00;38;5;7'
  'di=00;38;5;4'
  'ln=00;38;5;3'
  'or=00;38;5;1'
  'ex=00;38;5;10'
  'st=00;38;5;50'
  'so=00;38;5;6'
  'ma=00;38;5;14'
)

zstyle ':completion:*:default' list-colors "${zsh_completion_colors[@]}"
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path "$XDG_CACHE_HOME/zsh/.zcompcache"
zstyle -e ':completion:*:(ssh|scp|sftp|rsh|rsync):hosts' hosts \
  'reply=(${=${${(f)"$(cat /etc/ssh_hosts ~/.config/ssh/known_hosts 2>/dev/null)"}%%[# ]*}//,/ })'
