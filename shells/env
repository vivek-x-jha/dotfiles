# Shared environment variables for bash and zsh
# Zsh reaches this through ~/.zshenv, so keep essential CLI paths here for
# login, interactive, non-interactive, and agent-launched shells.

# XDG: https://specifications.freedesktop.org/basedir-spec/latest/#variables
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_STATE_HOME="$HOME/.local/state"

# VS Code: portable mode keeps macOS user, extension, and shared data out of $HOME.
[[ $(uname) == Darwin ]] && export VSCODE_PORTABLE="$XDG_DATA_HOME/vscode"

# Checkout location is persisted by bootstrap so non-default clones remain usable.
if [[ -z ${DOTFILES_DIR:-} && -r $XDG_STATE_HOME/dotfiles/root ]]; then
  IFS= read -r DOTFILES_DIR <"$XDG_STATE_HOME/dotfiles/root"
fi
export DOTFILES_DIR="${DOTFILES_DIR:-$HOME/.dotfiles}"

# Homebrew (MacOS only)
[[ $(uname) == Darwin ]] && {
  export HOMEBREW_NO_ENV_HINTS=1
  export HOMEBREW_INSTALL_BADGE=$'\e[95m\e[0m'
  # Inventory dumps are runtime snapshots; tracked profile manifests stay curated.
  export HOMEBREW_BUNDLE_FILE="$XDG_STATE_HOME/homebrew/Brewfile.snapshot"
}

# Shells
export SHELL_CONFIG="$XDG_CONFIG_HOME/shells"
export SHELL_THEME='sourdiesel'

# Zsh: https://zsh.sourceforge.io/Intro/intro_3.html
export ZDOTDIR="$SHELL_CONFIG/zsh"

# Zap: https://github.com/zap-zsh/zap?tab=readme-ov-file#example-usage
export ZAP_GIT_PREFIX='git@github.com:'

# Zsh/Bash: https://superuser.com/q/1610587/930403
export SHELL_SESSIONS_DISABLE=1

# Editor: https://wiki.archlinux.org/title/Environment_variables#Default_programs
export EDITOR=nvim
export VISUAL="$EDITOR"
export NVIM_LOG_FILE="$XDG_STATE_HOME/nvim/nvim.log"

# Pager: https://man7.org/linux/man-pages/man1/less.1.html
export PAGER='less -R'
export MANPAGER="$PAGER"

# Glow: https://github.com/charmbracelet/glow/discussions/799#discussioncomment-14866750
export GLAMOUR_STYLE="$XDG_CONFIG_HOME/glow/styles/sourdiesel.json"

# Matplotlib: https://matplotlib.org/stable/install/environment_variables_faq.html
export MPLCONFIGDIR="$XDG_CONFIG_HOME/matplotlib"

# Less: https://man7.org/linux/man-pages/man1/less.1.html
export LESSHISTFILE="$XDG_STATE_HOME/lesshst"

# MySQL: # https://dev.mysql.com/doc/refman/9.5/en/environment-variables.html
export MYSQL_HISTFILE="$XDG_STATE_HOME/mysql/.mysql_history"

# MyCLI: https://www.mycli.net/config
export MYCLI_HISTFILE="$XDG_STATE_HOME/mycli/.mycli_history"

# Python: https://docs.python.org/3/using/cmdline.html#envvar-PYTHON_HISTORY
export PYTHON_HISTORY="$XDG_STATE_HOME/python/.python_history"

# IPython profiles mix config with runtime DB/history files.
export IPYTHONDIR="$XDG_STATE_HOME/ipython"

# Jupyter: https://docs.jupyter.org/en/latest/use/jupyter-directories.html#environment-variables
export JUPYTER_CONFIG_DIR="$XDG_CONFIG_HOME/jupyter"
export JUPYTER_DATA_DIR="$XDG_DATA_HOME/jupyter"
export JUPYTER_RUNTIME_DIR="$XDG_STATE_HOME/jupyter/runtime"

# Rust toolchain
export CARGO_HOME="$XDG_DATA_HOME/cargo"
export RUSTUP_HOME="$XDG_DATA_HOME/rustup"

# TPM: https://github.com/tmux-plugins/tpm/blob/master/docs/changing_plugins_install_dir.md#changing-plugins-install-dir
export TMUX_PLUGIN_MANAGER_PATH="$XDG_DATA_HOME/tmux/plugins"

# Fzf shell integration popup geometry.
export FZF_TMUX_OPTS='-p 75%,75%'

# Tmux fzf: https://github.com/sainnhe/tmux-fzf?tab=readme-ov-file#key-binding
export TMUX_FZF_LAUNCH_KEY='f'
export TMUX_FZF_OPTIONS='-p 75%,75% -m --no-preview'

# 1password: https://developer.1password.com/docs/cli/shell-plugins
export OP_PLUGIN_ALIASES_SOURCED=1

# Eva: https://github.com/vivek-x-jha/eva
export EVA_COLORS="nb=00;38;5;0:nk=00;38;5;7:nm=00;38;5;3:ng=00;38;5;1:nt=00;38;5;6:lp=00;38;5;4:"

# Ripgrep: https://github.com/BurntSushi/ripgrep/blob/master/GUIDE.md#configuration-file
export RIPGREP_CONFIG_PATH="$XDG_CONFIG_HOME/ripgrep/config"

# npm: https://docs.npmjs.com/cli/v11/using-npm/config#environment-variables
export NPM_CONFIG_USERCONFIG="$XDG_CONFIG_HOME/npm/npmrc"

# Zoxide: https://github.com/ajeetdsouza/zoxide#environment-variables
export _ZO_DATA_DIR="$XDG_DATA_HOME/zoxide"

# Claude Code: https://code.claude.com/docs/en/env-vars
export CLAUDE_CONFIG_DIR="$XDG_CONFIG_HOME/claude"

# Codex: https://github.com/openai/codex/pull/4414
export CODEX_HOME="$XDG_STATE_HOME/codex"

# Hermes Agent: unified config, data, state, cache, and installation root.
export HERMES_HOME="$XDG_DATA_HOME/hermes"

# Ollama: local model runner/server used by Pi's OpenAI-compatible provider.
export OLLAMA_HOST="${OLLAMA_HOST:-127.0.0.1:11434}"
export OLLAMA_FLASH_ATTENTION="${OLLAMA_FLASH_ATTENTION:-1}"
export OLLAMA_KV_CACHE_TYPE="${OLLAMA_KV_CACHE_TYPE:-q8_0}"

# Pi coding agent: keep mutable auth, settings, packages, and sessions in XDG state.
export PI_CODING_AGENT_DIR="$XDG_STATE_HOME/pi/agent"

remove_path() {
  PATH=":$PATH:"
  PATH="${PATH//:$1:/:}"
  PATH="${PATH#:}"
  PATH="${PATH%:}"
}

prepend_path() { remove_path "$1" && PATH="$1${PATH:+:$PATH}"; }
append_path() { remove_path "$1" && PATH="${PATH:+$PATH:}$1"; }

# Add MacOS tools - Homebrew + iTerm2 utilities
[[ $(uname) == Darwin ]] && {
  prepend_path '/opt/homebrew/sbin'
  prepend_path '/opt/homebrew/bin'
  append_path '/Applications/iTerm.app/Contents/Resources/utilities'
}

# Add user-managed tool directories needed by editors, agents, and non-login zsh.
prepend_path "$HOME/.local/bin"
prepend_path "$XDG_DATA_HOME/fzf/bin"
prepend_path "$CARGO_HOME/bin"
prepend_path "$XDG_DATA_HOME/bob/nvim-bin"

export PATH

unset -f remove_path prepend_path append_path
