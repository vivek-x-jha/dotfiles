# Legacy personal config retained so pre-refactor directory symlinks keep
# working until bootstrap migrates them to a user-owned XDG SSH directory.
# New installations include auth/ssh/base instead of this file.
Include ~/.config/ssh/identities/1password

Host github.com
  HostName           github.com
  User               git

Host *
  UserKnownHostsFile ~/.config/ssh/known_hosts
  SendEnv            LANG LC_*
