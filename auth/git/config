# Legacy personal config retained so pre-refactor directory symlinks keep
# working until bootstrap migrates them to a user-owned XDG Git directory.
# New installations include auth/git/base instead of this file.
[init]
	defaultBranch = main
[user]
	name = Kristy Kamiyama
	email = kristy.kamiyama@gmail.com
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIKhjG7V84zMNUo6QXOSYmp+T+bi+kZ2CrRXPOqHKofR4
[pull]
	ff = only
[core]
	sshCommand = ssh -F ~/.config/ssh/config
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.config/ssh/allowed_signers
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
[commit]
	gpgsign = true
[include]
	path = ~/.config/git/themes/sourdiesel
