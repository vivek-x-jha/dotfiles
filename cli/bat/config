# https://github.com/sharkdp/bat/blob/master/README.md

# Options
--theme='sourdiesel'
--tabs=2
--line-range=:1000
--italic-text=always

# Syntaxes
--map-syntax "**/bat/config:conf"
--map-syntax "**/fzf/config:Dotfiles Bash"
--map-syntax "**/git/config:Dotfiles Git Config"
--map-syntax "**/git/themes/*:Dotfiles Git Config"
--map-syntax "**/mycli/config:ini"
--map-syntax "**/ripgrep/config:conf"
--map-syntax "**/shells/bash/comps/*:Dotfiles Bash"
--map-syntax "**/shells/bash/funcs/*:Dotfiles Bash"
--map-syntax "**/shells/bash/keymaps/*:Dotfiles Bash"
--map-syntax "**/shells/colors/*:Dotfiles Zsh"
--map-syntax "**/shells/zsh/comps/*:Dotfiles Zsh"
--map-syntax "**/shells/zsh/funcs/*:Dotfiles Zsh"
--map-syntax "**/shells/zsh/keymaps/*:Dotfiles Zsh"
--map-syntax "*.bash:Dotfiles Bash"
--map-syntax "*.sh:Dotfiles Bash"
--map-syntax "*.zsh:Dotfiles Zsh"
--map-syntax ".bash_profile:Dotfiles Bash"
--map-syntax ".bashrc:Dotfiles Bash"
--map-syntax ".zprofile:Dotfiles Zsh"
--map-syntax ".zshenv:Dotfiles Zsh"
--map-syntax ".zshrc:Dotfiles Zsh"
# Custom bat syntax mirrors Neovim's built-in `sshconfig` filetype.
--map-syntax "**/ssh/config*:Neovim SSH Config"
--map-syntax "**/ssh/identities/*:Neovim SSH Config"
--map-syntax "**/tmux/tmux.conf:Dotfiles Tmux"
--map-syntax "tmux.conf:Dotfiles Tmux"
--map-syntax "aliases:Dotfiles Zsh"
--map-syntax "env:Dotfiles Zsh"
--map-syntax "profile:Dotfiles Zsh"
--map-syntax "*.js:JavaScript"
--map-syntax "*.ino:C++"
--map-syntax ".ignore:gitignore"
