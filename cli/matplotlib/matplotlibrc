# Display and export defaults
figure.dpi: 120
savefig.dpi: 300
savefig.bbox: tight

# Font defaults
font.family: sans-serif
font.sans-serif: JetBrains Mono, DejaVu Sans, Arial
font.size: 11

# Axes defaults
axes.grid: True
axes.spines.top: False
axes.spines.right: False
axes.titlesize: 13
axes.labelsize: 11

# Line and marker defaults
lines.linewidth: 2
lines.markersize: 6

# Tick and legend defaults
xtick.labelsize: 10
ytick.labelsize: 10
legend.frameon: False
legend.fontsize: 10

# Color defaults
image.cmap: viridis
