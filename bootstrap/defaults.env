# shellcheck shell=bash
# shellcheck disable=SC2034

# auto reports fresh or partial from live state; behavior remains convergent in both cases.
BOOTSTRAP_PROFILE=auto
BOOTSTRAP_INTERACTIVE=0
BOOTSTRAP_ONLY_TARGETS=''
BOOTSTRAP_SKIP_TARGETS=''

# Secret-backed integrations stay opt-in for zero-shot runs.
BOOTSTRAP_ENABLE_1PASSWORD=0

# Core setup path.
BOOTSTRAP_INSTALL_PACKAGES=1
BOOTSTRAP_INSTALL_FZF=1
BOOTSTRAP_INSTALL_GH=1
BOOTSTRAP_INSTALL_GLOW=1
BOOTSTRAP_INSTALL_HERDR=1
BOOTSTRAP_COLLECT_ENVIRONMENT=1
BOOTSTRAP_CREATE_SYMLINKS=1
BOOTSTRAP_CONFIGURE_CODEX=1
BOOTSTRAP_INSTALL_PERSONAL_AI_SKILLS=0
BOOTSTRAP_CONFIGURE_OS=1
BOOTSTRAP_CONFIGURE_GIT=1
BOOTSTRAP_GH_AUTH=0
BOOTSTRAP_INSTALL_SHELL_PLUGINS=1
BOOTSTRAP_LOAD_BAT_THEMES=1
BOOTSTRAP_CONFIGURE_HAMMERSPOON=1
BOOTSTRAP_INSTALL_RUST_TOOLING=1
BOOTSTRAP_SETUP_IDE=1
BOOTSTRAP_INSTALL_NVIM_NIGHTLY=0

# Optional or high-risk setup phases.
BOOTSTRAP_CLONE_DEVELOPER_REPOS=0
BOOTSTRAP_INSTALL_TEMPLATES=0
BOOTSTRAP_SETUP_ATUIN_SYNC=0
BOOTSTRAP_CONFIGURE_SUDO_AUTH=0
BOOTSTRAP_CHANGE_SHELL=0
BOOTSTRAP_INSTALL_LINUX_GUI_APPS=0

# Package-manager defaults. Profiles are cumulative: core < developer < personal.
BOOTSTRAP_BREW_PROFILE=personal
# Set a path/URL to replace profile assembly with one custom Brewfile.
BOOTSTRAP_BREWFILE=''
BOOTSTRAP_BREW_CASK_MODE=all
BOOTSTRAP_BREW_CASKS=''
BOOTSTRAP_BREW_SKIP_CASKS=''
BOOTSTRAP_BREW_REFRESH_SNAPSHOT=0
BOOTSTRAP_BREW_CLEANUP=0
BOOTSTRAP_BREW_UPGRADE=0
BOOTSTRAP_APT_UPDATE=1
BOOTSTRAP_APT_UPGRADE=0
BOOTSTRAP_DNF_UPGRADE=0

# Retry transient network operations. Resume is enabled only by --resume.
BOOTSTRAP_RETRY_ATTEMPTS=3
BOOTSTRAP_RETRY_DELAY=3

# Identity defaults. Leave empty to derive from existing git config or user/host.
BOOTSTRAP_GIT_NAME=''
BOOTSTRAP_GIT_EMAIL=''
BOOTSTRAP_GITHUB_NAME=''
BOOTSTRAP_CONFIGURE_GIT_REMOTE=0
BOOTSTRAP_GIT_REMOTE=''
BOOTSTRAP_GIT_SIGN_COMMITS=0
BOOTSTRAP_GIT_SIGNING_KEY=''
BOOTSTRAP_GIT_SIGNING_PROGRAM=''
BOOTSTRAP_GIT_ALLOWED_SIGNERS_FILE=''
BOOTSTRAP_OP_VAULT=Private
BOOTSTRAP_ATUIN_OP_TITLE='Atuin Sync'
BOOTSTRAP_ATUIN_USERNAME=''
BOOTSTRAP_ATUIN_EMAIL=''
BOOTSTRAP_MEDIA=''
